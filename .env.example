# Context7 API Configuration (Optional - for enhanced documentation search)
# Get your API key from: https://context7.com (sign up for account)
# Provides up-to-date documentation and code examples
CONTEXT7_API_KEY=ctx7sk-your_context7_api_key_here

# BookStack API Configuration
# Create API tokens in BookStack Settings > API Tokens
# Provides access to your self-hosted documentation
BOOKSTACK_URL=https://your-bookstack-instance.com
BOOKSTACK_TOKEN_ID=your_token_id_here
BOOKSTACK_TOKEN_SECRET=your_token_secret_here


# OpenAI API Configuration (Required for PDF Receipt Parsing)
# Get your API key from: https://platform.openai.com/api-keys
# Used for GPT-4o Vision to extract structured data from grocery receipts
# Pricing: ~$0.01-0.03 per receipt (depending on length)
# Free tier: $5 credit for new accounts, then pay-as-you-go
OPENAI_API_KEY=sk-your_openai_api_key_here

# Maker Image Converter Configuration (Optional)
# Override local path to maker-image-converter repository when using maker_image_convert
MAKER_IMAGE_CONVERTER_ROOT=C:/Users/Deej/Repos/maker-image-converter

# GitHub API Configuration (Optional - for enhanced search results)
# Create a personal access token at: https://github.com/settings/tokens
# Only needs 'public_repo' scope for searching public repositories
GITHUB_TOKEN=ghp_your_github_token_here

# Local media service configuration (Optional)
# These power local_* MCP tools that call your FastAPI wrappers.
LOCAL_IMAGE_SERVER_URL=http://127.0.0.1:8189
LOCAL_TTS_SERVER_URL=http://127.0.0.1:8190
LOCAL_VIDEO_SERVER_URL=http://127.0.0.1:8191

# OpenRouter API Configuration (Optional - alternative to OpenAI)
# Get your API key from: https://openrouter.ai/
# Used as an alternative LLM provider for any LLM tasks
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here

# Vikunja Task Manager (Self-hosted)
# Install Vikunja from vikunja.io, generate an API token in Profile Settings
VIKUNJA_API_URL=https://tasks.deejpotter.com
VIKUNJA_API_TOKEN=tk_your_vikunja_api_token_here
